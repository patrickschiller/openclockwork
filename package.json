{
  "name": "openclockwork",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "OpenClockwork — open-source digital time-and-attendance management",
  "homepage": "https://github.com/patrickschiller/openclockwork",
  "repository": {
    "type": "git",
    "url": "https://github.com/patrickschiller/openclockwork.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "db:up": "docker compose up -d db",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:demo-reset": "node --import tsx prisma/demo-reset.ts",
    "generate:api": "ts-node --project apps/api/tsconfig.app.json --transpile-only apps/api/src/generate-openapi.ts && openapi-typescript apps/api/openapi.json -o apps/web/src/api/generated.ts",
    "verify:api": "pnpm generate:api && git diff --exit-code -- apps/api/openapi.json apps/web/src/api/generated.ts"
  },
